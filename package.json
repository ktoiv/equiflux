{
	"name": "electrobun-react-tailwind-vite",
	"type": "module",
	"version": "1.0.0",
	"description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
	"bin": {
		"equiflux": "./src/bun/cli.ts"
	},
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"cli": "bun run src/bun/cli.ts --",
		"build:cli": "bun build src/bun/cli.ts --compile --outfile=equiflux",
		"build:cli:all": "bun build src/bun/cli.ts --compile --target=bun-linux-x64-modern --outfile=equiflux-linux-x64 && bun build src/bun/cli.ts --compile --target=bun-linux-arm64 --outfile=equiflux-linux-arm64 && bun build src/bun/cli.ts --compile --target=bun-darwin-x64 --outfile=equiflux-darwin-x64 && bun build src/bun/cli.ts --compile --target=bun-darwin-arm64 --outfile=equiflux-darwin-arm64 && bun build src/bun/cli.ts --compile --target=bun-windows-x64-modern --outfile=equiflux-win-x64.exe",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"format": "prettier --write \"src/**/*.{ts,tsx,css,html}\"",
		"format:check": "prettier --check \"src/**/*.{ts,tsx,css,html}\"",
		"prepare": "husky",
		"lint-staged": "lint-staged"
	},
	"dependencies": {
		"@tanstack/react-pacer": "^0.22.0",
		"@tanstack/react-query": "^5.100.9",
		"electrobun": "1.18.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"recharts": "^3.8.1",
		"yahoo-finance2": "^3.15.2",
		"zod": "^4.4.3"
	},
	"lint-staged": {
		"*.{ts,tsx}": ["eslint --fix", "prettier --write"],
		"*.{css,html}": ["prettier --write"]
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@typescript-eslint/eslint-plugin": "^8.59.2",
		"@typescript-eslint/parser": "^8.59.2",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.3",
		"postcss": "^8.4.49",
		"prettier": "^3.8.3",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
